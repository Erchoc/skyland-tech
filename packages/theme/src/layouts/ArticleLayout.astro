---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import TableOfContents from "../components/article/TableOfContents.astro";
import TitleReveal from "../components/ui/TitleReveal.astro";
import { loadThemeConfig } from "../config/loader.ts";
import { tagToSlug } from "../utils/tag-slug.ts";
import type { MarkdownHeading, ImageMetadata } from "astro";

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  author: string;
  cover?: ImageMetadata;
  tags: string[];
  readingTime: string;
  headings: MarkdownHeading[];
  series?: string;
  slug: string;
  prevPost?: { slug: string; title: string };
  nextPost?: { slug: string; title: string };
}

const {
  title, subtitle, description, date, updatedDate, author, cover,
  tags, readingTime, headings, series, slug, prevPost, nextPost,
} = Astro.props;

const formattedDate = date.toLocaleDateString("zh-CN", {
  year: "numeric", month: "long", day: "numeric",
});
const formattedUpdated = updatedDate?.toLocaleDateString("zh-CN", {
  year: "numeric", month: "long", day: "numeric",
});
const config = loadThemeConfig();
const weights = config.search.weights;
const titleEnabled = config.features.animation && config.animation.apply_to.includes("article-title");
const subtitleEnabled = config.features.animation && config.animation.apply_to.includes("article-subtitle");
---

<BaseLayout title={`${title} — 空岛云技术`} description={description}>
  <Header title="空岛云技术" variant="dark" />
  <main>
    {/* Dark article header — full width, seamless with dark header */}
    <div style="background-color: var(--color-dark-bg);">
      <div class="mx-auto max-w-[1150px] px-6 py-10 sm:py-14 lg:px-8 lg:py-16">
        {series && (
          <p class="label-uppercase" style="color: var(--color-accent-dark);">{series}</p>
        )}

        <div data-pagefind-weight={weights.title}>
          <TitleReveal
            text={title}
            as="h1"
            class="mt-3 max-w-3xl"
            style={`font-family: var(--font-heading); font-feature-settings: "kern" 1; font-weight: 600; font-size: clamp(1.875rem, 4vw + 0.5rem, 3.25rem); line-height: 1.17; color: var(--color-dark-text);`}
            enabled={titleEnabled}
          />
        </div>

        {subtitle && (
          <TitleReveal
            text={subtitle}
            as="p"
            delay={350}
            class="mt-4 max-w-2xl text-[1.25rem] leading-relaxed"
            style="color: var(--color-dark-text-secondary);"
            enabled={subtitleEnabled}
          />
        )}

        <div class="mt-6 flex flex-wrap items-center gap-3 text-[13px]" style="color: var(--color-text-helper);">
          <span data-pagefind-meta="author">{author}</span>
          <span style="color: var(--color-border-strong);">·</span>
          <time datetime={date.toISOString()} data-pagefind-meta="date">{formattedDate}</time>
          {formattedUpdated && (
            <>
              <span style="color: var(--color-border-strong);">·</span>
              <span data-pagefind-ignore>更新于 {formattedUpdated}</span>
            </>
          )}
          <span style="color: var(--color-border-strong);">·</span>
          <span>{readingTime}</span>
          <span style="color: var(--color-border-strong);">·</span>
          <a
            href={`/slides/${slug}`}
            class="transition-colors hover:underline"
            style="color: var(--color-accent-dark);"
          >
            演讲模式
          </a>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tagToSlug(tag)}`}
              class="text-[13px] font-medium transition-colors"
              style={`
                padding: 3px 8px;
                border-radius: var(--radius-md);
                background: rgba(255,255,255,0.08);
                color: var(--color-dark-text-secondary);
              `}
              data-pagefind-weight={weights.tags}
              data-pagefind-filter={`tag:${tag}`}
            >
              {tag}
            </a>
          ))}
        </div>
      </div>
    </div>

    {/* Article body */}
    <div class="mx-auto max-w-[1150px] px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-[1fr_200px] lg:gap-16">
        {/* Main content */}
        <article class="mx-auto w-full max-w-[65ch] py-12 lg:py-16" data-pagefind-body>
          <div class="article-prose">
            <slot />
          </div>

          {/* Series nav */}
          {(prevPost || nextPost) && (
            <nav class="mt-16 grid gap-4 pt-8 sm:grid-cols-2" style="border-top: 1px solid var(--border);">
              {prevPost && (
                <a
                  href={`/posts/${prevPost.slug}`}
                  class="group block p-4 transition-colors"
                  style={`border: 1px solid var(--border); border-radius: var(--radius-lg);`}
                >
                  <span class="text-[13px]" style="color: var(--text-helper);">上一篇</span>
                  <p class="mt-1 text-[15px] font-medium" style="color: var(--text);">{prevPost.title}</p>
                </a>
              )}
              {nextPost && (
                <a
                  href={`/posts/${nextPost.slug}`}
                  class="group block p-4 text-right transition-colors"
                  style={`border: 1px solid var(--border); border-radius: var(--radius-lg);`}
                >
                  <span class="text-[13px]" style="color: var(--text-helper);">下一篇</span>
                  <p class="mt-1 text-[15px] font-medium" style="color: var(--text);">{nextPost.title}</p>
                </a>
              )}
            </nav>
          )}
        </article>

        {/* TOC sidebar */}
        <aside class="hidden lg:block">
          <div class="sticky top-20 pt-12 lg:pt-16">
            <TableOfContents headings={headings} />
          </div>
        </aside>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
