---
const year = new Date().getFullYear();
---

<footer class="mt-10 py-5" style={`border-top: 1px solid var(--border);`}>
  <div class="mx-auto max-w-[1150px] px-6 lg:px-8">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <p class="text-[13px]" style="color: var(--text-helper);">
        &copy; {year} · Built with Astro
      </p>
      <p class="text-[13px]" style="color: var(--text-helper);">
        Designed for engineers
      </p>
    </div>
  </div>
</footer>
