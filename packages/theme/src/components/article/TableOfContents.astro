---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{toc.length > 0 && (
  <nav data-pagefind-ignore>
    <p class="label-uppercase mb-4" style="color: var(--text-helper);">目录</p>
    <ul style="border-left: 1px solid var(--border);">
      {toc.map((heading) => (
        <li style={`padding-left: ${(heading.depth - 2) * 12 + 12}px;`}>
          <a
            href={`#${heading.slug}`}
            class="block py-1 text-[13px] leading-snug transition-colors"
            style="color: var(--text-helper);"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
