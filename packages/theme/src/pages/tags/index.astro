---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
const totalPosts = posts.length;
---

<BaseLayout title="标签 — 空岛云技术">
  <Header title="空岛云技术" />
  <main class="mx-auto max-w-[720px] px-6 py-20 lg:py-28">
    <div class="text-center">
      <p class="label-uppercase" style="color: var(--text-helper);">标签</p>
      <h1
        class="mt-3"
        style={`font-family: var(--font-heading); font-weight: 600; font-size: 2.125rem; line-height: 1.19; color: var(--text);`}
      >
        所有标签
      </h1>
      <p class="mt-3 text-[15px]" style="color: var(--text-helper);">
        {tags.length} 个标签 · {totalPosts} 篇文章
      </p>
    </div>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}`}
          class="tag-pill text-[15px] font-medium transition-all duration-150"
          style={`
            padding: 10px 16px;
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            box-shadow: var(--shadow-whisper);
          `}
        >
          {tag}
          <span class="ml-1.5 text-[13px]" style="color: var(--text-helper);">{count}</span>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .tag-pill:hover {
    border-color: var(--link) !important;
    color: var(--link) !important;
    box-shadow: 0 0 0 1px var(--link) !important;
  }
</style>
