---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} — Slides</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="mdx-source" style="display: none;">
      <Content />
    </div>
    <div id="slide-app"></div>

    <script define:vars={{ title: post.data.title }}>
      // Slide presentation engine — pure vanilla JS
      const source = document.getElementById("mdx-source");
      const app = document.getElementById("slide-app");

      if (source && app) {
        const parts = source.innerHTML.split(/<hr\s*\/?>/);
        const slides = [
          `<h1 style="font-size: clamp(2rem, 5vw, 4rem); font-weight: 600; line-height: 1.17; font-family: 'DM Sans', sans-serif;">${title}</h1>`,
          ...parts.map(s => s.trim()).filter(Boolean),
        ];

        let current = 0;
        const total = slides.length;
        let touchStartX = 0;

        function render() {
          app.innerHTML = `
            <div style="position:fixed;inset:0;z-index:9999;background:#15181e;color:#efeff1;font-family:system-ui,-apple-system,sans-serif;display:flex;flex-direction:column;">
              <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:clamp(24px,5vw,80px);overflow:auto;">
                <div style="max-width:900px;width:100%;animation:slideIn 0.3s ease;">
                  ${slides[current]}
                </div>
              </div>
              <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 24px;border-top:1px solid rgba(97,104,117,0.3);font-size:13px;color:#656a76;">
                <div style="display:flex;gap:16px;">
                  <button id="prev-btn" style="background:none;border:none;color:${current === 0 ? '#3b3d45' : '#d5d7db'};cursor:${current === 0 ? 'default' : 'pointer'};padding:4px 8px;font-size:13px;">← Prev</button>
                  <button id="next-btn" style="background:none;border:none;color:${current === total - 1 ? '#3b3d45' : '#d5d7db'};cursor:${current === total - 1 ? 'default' : 'pointer'};padding:4px 8px;font-size:13px;">Next →</button>
                </div>
                <div><span style="color:#d5d7db">${current + 1}</span> / ${total}</div>
                <div style="display:flex;gap:8px;"><span>← → Navigate</span><span>·</span><span>F Fullscreen</span></div>
              </div>
            </div>
            <style>
              @keyframes slideIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
              #slide-app h1,#slide-app h2,#slide-app h3 { font-family:'DM Sans','Noto Sans SC',sans-serif; font-weight:700; margin-bottom:0.5em; }
              #slide-app h2 { font-size:1.75rem; line-height:1.19; }
              #slide-app h3 { font-size:1.375rem; line-height:1.19; }
              #slide-app p { margin-bottom:1em; line-height:1.63; font-size:1.0625rem; }
              #slide-app ul,#slide-app ol { padding-left:1.5rem; margin-bottom:1em; }
              #slide-app li { margin-bottom:0.5rem; line-height:1.5; }
              #slide-app pre { background:#0d0e12; padding:1.25rem; border-radius:8px; overflow-x:auto; margin:1rem 0; font-size:0.875rem; }
              #slide-app code { font-family:'JetBrains Mono',monospace; font-size:0.875em; }
              #slide-app a { color:#1060ff; }
              #slide-app table { border-collapse:collapse; width:100%; margin:1rem 0; }
              #slide-app th,#slide-app td { border:1px solid rgba(97,104,117,0.3); padding:8px 12px; text-align:left; font-size:0.875rem; }
              #slide-app th { background:rgba(255,255,255,0.05); font-weight:600; }
              #slide-app img { max-width:100%; height:auto; border-radius:8px; }
            </style>
          `;

          document.getElementById("prev-btn")?.addEventListener("click", () => { if (current > 0) { current--; render(); } });
          document.getElementById("next-btn")?.addEventListener("click", () => { if (current < total - 1) { current++; render(); } });
        }

        window.addEventListener("keydown", (e) => {
          if (e.key === "ArrowRight" || e.key === " ") { e.preventDefault(); if (current < total - 1) { current++; render(); } }
          if (e.key === "ArrowLeft") { e.preventDefault(); if (current > 0) { current--; render(); } }
          if (e.key === "f" || e.key === "F") { document.fullscreenElement ? document.exitFullscreen() : app.requestFullscreen(); }
        });

        app.addEventListener("touchstart", (e) => { touchStartX = e.touches[0].clientX; });
        app.addEventListener("touchend", (e) => {
          const delta = e.changedTouches[0].clientX - touchStartX;
          if (Math.abs(delta) > 50) { delta < 0 ? (current < total - 1 && (current++, render())) : (current > 0 && (current--, render())); }
        });

        render();
      }
    </script>
  </body>
</html>
