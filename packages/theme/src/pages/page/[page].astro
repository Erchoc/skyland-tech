---
import { getCollection } from "astro:content";
import Footer from "../../components/layout/Footer.astro";
import Header from "../../components/layout/Header.astro";
import PostCard from "../../components/ui/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildPaginationItems, pageUrl } from "../../utils/pagination.ts";
import { getReadingTime } from "../../utils/reading-time.ts";

type CardData = {
  id: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  cover?: any;
  readingTime: string;
};

export async function getStaticPaths() {
  // getStaticPaths 在 Astro 独立沙箱执行，无法闭包 frontmatter top-level 常量
  const POSTS_PER_PAGE = 12;
  const mockPage = import.meta.env.MOCK_POSTS === "1";
  const real = (await getCollection("posts", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );

  const toCard = (p: { id: string; data: any; body?: string }): CardData => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    date: p.data.date,
    tags: p.data.tags,
    cover: p.data.cover,
    readingTime: getReadingTime(p.body ?? ""),
  });

  let allCards: CardData[] = real.map(toCard);

  if (mockPage) {
    const mockTags = [
      "Kubernetes",
      "Docker",
      "Node.js",
      "性能优化",
      "架构设计",
      "云原生",
      "微服务",
      "CI/CD",
      "监控",
      "安全",
    ];
    const categories = ["架构设计", "工程实践", "性能优化", "基础设施"];
    allCards = Array.from({ length: 100 }, (_, i) => {
      const base = real[i % real.length];
      const d = new Date(2026, 0, 1);
      d.setDate(d.getDate() + i);
      return toCard({
        id: `mock-post-${i + 1}`,
        data: {
          title: `${categories[i % categories.length]}实践 #${i + 1}：${base.data.title}`,
          description: base.data.description,
          date: d,
          tags: [mockTags[i % mockTags.length], mockTags[(i + 3) % mockTags.length]],
          cover: base.data.cover,
        },
        body: base.body,
      });
    }).sort((a, b) => b.date.valueOf() - a.date.valueOf());
  }

  const [, ...rest] = allCards;
  const totalPages = Math.max(1, Math.ceil(rest.length / POSTS_PER_PAGE));

  // featured 占第 1 篇，第 1 页挂在 "/"，这里只生成第 2 页起
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
    const currentPage = i + 2;
    return {
      params: { page: String(currentPage) },
      props: {
        currentPage,
        totalPages,
        totalCount: allCards.length,
        pagedPosts: rest.slice((currentPage - 1) * POSTS_PER_PAGE, currentPage * POSTS_PER_PAGE),
        paginationItems: buildPaginationItems(currentPage, totalPages),
      },
    };
  });
}

const { currentPage, totalPages, totalCount, pagedPosts, paginationItems } = Astro.props;
---

<BaseLayout title={`第 ${currentPage} 页 — 空岛云技术`} description="纯技术 + 架构设计文章合集">
  <Header title="空岛云技术" />
  <main>
    <section class="mx-auto max-w-[1150px] px-6 pt-16 pb-8 lg:px-8 lg:pt-20 lg:pb-10">
      <div class="mb-6 flex items-baseline justify-between">
        <p class="label-uppercase" style="color: var(--text-helper);">
          所有文章 · 第 {currentPage} 页
        </p>
        <p class="text-[13px]" style="color: var(--text-helper);">
          共 {totalCount} 篇
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {pagedPosts.map((post) => (
          <PostCard
            title={post.title}
            description={post.description}
            date={post.date}
            tags={post.tags}
            cover={post.cover}
            slug={post.id}
            readingTime={post.readingTime}
          />
        ))}
      </div>

      <nav class="mt-12 flex items-center justify-center gap-2" aria-label="分页">
        {currentPage > 1 ? (
          <a href={pageUrl(currentPage - 1)} class="pagination-btn" aria-label="上一页">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </a>
        ) : (
          <span class="pagination-btn disabled" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </span>
        )}

        {paginationItems.map((item) =>
          item.type === "ellipsis" ? (
            <span class="pagination-ellipsis">···</span>
          ) : item.active ? (
            <span class="pagination-btn active" aria-current="page">{item.value}</span>
          ) : (
            <a href={item.href} class="pagination-btn">{item.value}</a>
          )
        )}

        {currentPage < totalPages ? (
          <a href={pageUrl(currentPage + 1)} class="pagination-btn" aria-label="下一页">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        ) : (
          <span class="pagination-btn disabled" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </span>
        )}
      </nav>
    </section>
  </main>
  <Footer />
</BaseLayout>
