---
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import HeroSection from "../components/ui/HeroSection.astro";
import PostCard from "../components/ui/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildPaginationItems, pageUrl } from "../utils/pagination.ts";
import { getReadingTime } from "../utils/reading-time.ts";

const POSTS_PER_PAGE = 12;
const mockPage = import.meta.env.MOCK_POSTS === "1";

const realPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

type SimplePost = {
  id: string;
  data: {
    title: string;
    description: string;
    date: Date;
    tags: string[];
    cover?: ImageMetadata;
    draft: boolean;
  };
  body?: string;
};

let allPosts: SimplePost[] = realPosts.map((p) => ({
  id: p.id,
  data: {
    title: p.data.title,
    description: p.data.description,
    date: p.data.date,
    tags: p.data.tags,
    cover: p.data.cover,
    draft: false,
  },
  body: p.body,
}));

if (mockPage) {
  const tags = [
    "Kubernetes",
    "Docker",
    "Node.js",
    "性能优化",
    "架构设计",
    "云原生",
    "微服务",
    "CI/CD",
    "监控",
    "安全",
  ];
  const categories = ["架构设计", "工程实践", "性能优化", "基础设施"];
  allPosts = Array.from({ length: 100 }, (_, i) => {
    const base = realPosts[i % realPosts.length];
    const d = new Date(2026, 0, 1);
    d.setDate(d.getDate() + i);
    return {
      id: `mock-post-${i + 1}`,
      data: {
        title: `${categories[i % categories.length]}实践 #${i + 1}：${base.data.title}`,
        description: base.data.description,
        date: d,
        tags: [tags[i % tags.length], tags[(i + 3) % tags.length]],
        cover: base.data.cover,
        draft: false,
      },
      body: base.body,
    };
  }).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
}

const [featured, ...rest] = allPosts;
const page1Posts = rest.slice(0, POSTS_PER_PAGE);
const totalPages = Math.max(1, Math.ceil(rest.length / POSTS_PER_PAGE));
const paginationItems = buildPaginationItems(1, totalPages);
---

<BaseLayout title="空岛云技术" description="纯技术 + 架构设计文章合集">
  <Header title="空岛云技术" variant="dark" />
  <main>
    <HeroSection title="空岛云技术" description="纯技术 + 架构设计文章合集" />

    <section class="mx-auto max-w-[1150px] px-6 pt-16 pb-8 lg:px-8 lg:pt-20 lg:pb-10">
      {featured && (
        <div class="mb-16">
          <p class="label-uppercase mb-6" style="color: var(--text-helper);">精选文章</p>
          <PostCard
            title={featured.data.title}
            description={featured.data.description}
            date={featured.data.date}
            tags={featured.data.tags}
            cover={featured.data.cover}
            slug={featured.id}
            readingTime={getReadingTime(featured.body ?? "")}
            featured
          />
        </div>
      )}

      {page1Posts.length > 0 && (
        <div>
          <div class="mb-6 flex items-baseline justify-between">
            <p class="label-uppercase" style="color: var(--text-helper);">所有文章</p>
            <p class="text-[13px]" style="color: var(--text-helper);">
              共 {rest.length + 1} 篇
            </p>
          </div>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {page1Posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                tags={post.data.tags}
                cover={post.data.cover}
                slug={post.id}
                readingTime={getReadingTime(post.body ?? "")}
              />
            ))}
          </div>
        </div>
      )}

      {totalPages > 1 && (
        <nav class="mt-12 flex items-center justify-center gap-2" aria-label="分页">
          <span class="pagination-btn disabled" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </span>

          {paginationItems.map((item) =>
            item.type === "ellipsis" ? (
              <span class="pagination-ellipsis">···</span>
            ) : item.active ? (
              <span class="pagination-btn active" aria-current="page">{item.value}</span>
            ) : (
              <a href={item.href} class="pagination-btn">{item.value}</a>
            )
          )}

          <a href={pageUrl(2)} class="pagination-btn" aria-label="下一页">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        </nav>
      )}
    </section>
  </main>
  <Footer />
</BaseLayout>
